<Window x:Class="WpfApp22.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="174" Width="300"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Введите пароль для подтверждения действия:"
                   Grid.Row="0" Margin="0,0,0,10" TextWrapping="Wrap"/>

        <!-- PasswordBox скрывает символы -->
        <PasswordBox x:Name="PasswordBox" Grid.Row="1" Margin="0,0,0,15"
                     VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- IsDefault="True" — Enter нажимает ОК -->
            <Button Content="ОК" x:Name="OkButton" Width="80" Margin="0,0,10,0"
                    Click="OkButton_Click" IsDefault="True"/>
            <!-- IsCancel="True" — Esc закрывает как «Отмена» -->
            <Button Content="Отмена" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>