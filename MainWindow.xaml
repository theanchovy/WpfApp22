<Window x:Class="WpfApp22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Напоминалка событий" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок управления -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="Загрузить ближайшие события"
                    AutomationProperties.Name="Загрузить список ближайших событий"
                    Click="LoadUpcomingEvents_Click"
                    MinWidth="120" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Добавить событие"
                    AutomationProperties.Name="Добавить новое событие"
                    Click="AddEvent_Click"
            MinWidth="100" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Редактировать"
                    AutomationProperties.Name="Редактировать выбранное событие"
            Click="EditEvent_Click"
            MinWidth="90" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Удалить"
            AutomationProperties.Name="Удалить выбранное событие"
            Click="DeleteEvent_Click"
            MinWidth="80" Padding="10,5"/>
        </StackPanel>

        <!-- Список событий -->
        <ListView x:Name="EventsList" Grid.Row="1" Margin="0,10,0,10"
                 SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"
                DisplayMemberBinding="{Binding Id}" Width="50"/>
                    <GridViewColumn Header="Дата"
                DisplayMemberBinding="{Binding EventDate, StringFormat=dd.MM.yyyy}"
                Width="100"/>
                    <GridViewColumn Header="Название"
                DisplayMemberBinding="{Binding Title}"
                Width="250"/>
                    <GridViewColumn Header="Праздник"
                DisplayMemberBinding="{Binding IsHoliday}"
                Width="80"/>
                    <GridViewColumn Header="Описание"
                DisplayMemberBinding="{Binding Description}"
                Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Диалоговое окно для добавления/редактирования -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1"
               Background="LightBlue" Padding="15" Visibility="Collapsed"
               x:Name="EventDialog" Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                      From="0" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <!-- Заголовок диалогового окна -->
                <TextBlock x:Name="DialogTitle" Text="Добавление события"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                <!-- Поле для названия события -->
                <TextBox x:Name="TitleTextBox"
                         Height="25"
                         Margin="0,0,0,10"
                         Padding="5"
                         Background="White"
                         Foreground="Gray"
                         Text="Название события"
                         TextChanged="TitleTextBox_TextChanged"
                         GotFocus="TitleTextBox_GotFocus"
                         LostFocus="TitleTextBox_LostFocus"/>

                <!-- Выбор даты -->
                <DatePicker x:Name="DatePicker" Margin="0,0,0,10"/>

                <!-- Чекбокс для отметки праздника -->
                <CheckBox x:Name="IsHolidayCheckBox" Content="Это праздник" Margin="0,0,0,10"/>

                <!-- Подпись для поля описания -->
                <TextBlock Text="Описание события (необязательно):"
                   Margin="0,0,0,5" FontWeight="Normal" Foreground="Gray"/>

                <!-- Поле для описания -->
                <TextBox x:Name="DescriptionTextBox"
                         Height="60"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,15"
                         BorderThickness="1"
                         Padding="5"
                         Background="White"
                         Foreground="LightGray"
                         Text="Введите описание события..."
                         TextChanged="DescriptionTextBox_TextChanged"
                         GotFocus="DescriptionTextBox_GotFocus"
                         LostFocus="DescriptionTextBox_LostFocus"/>

                <!-- Панель кнопок в диалоговом окне -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Сохранить"
                    AutomationProperties.Name="Сохранить событие"
            Click="SaveEvent_Click" MinWidth="80" Padding="10,5" Margin="0,0,10,0"/>
                    <Button Content="Отмена"
            AutomationProperties.Name="Отмена операции"
            Click="CancelDialog_Click" IsCancel="True" MinWidth="80" Padding="10,5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>