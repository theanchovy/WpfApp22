<Window x:Class="WpfApp22.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp22"
        mc:Ignorable="d"
        Title="Планировщик событий" Height="550" Width="800">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель кнопок управления -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <Button Content="Загрузить ближайшие события"
                    AutomationProperties.Name="Загрузить список ближайших событий"
                    Click="LoadUpcomingEvents_Click"
                    MinWidth="120" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Добавить событие"
                    AutomationProperties.Name="Добавить новое событие"
                    Click="AddEvent_Click"
            MinWidth="100" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Редактировать"
                    AutomationProperties.Name="Редактировать выбранное событие"
            Click="EditEvent_Click"
            MinWidth="90" Padding="10,5" Margin="0,0,10,0"/>

            <Button Content="Удалить"
            AutomationProperties.Name="Удалить выбранное событие"
            Click="DeleteEvent_Click"
            MinWidth="80" Padding="10,5"/>
        </StackPanel>

        <!-- Панель поиска -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,15">
            <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <TextBox x:Name="SearchTextBox"
             Height="25"
             Margin="0,0,10,0"
             Padding="5"
             Background="White"
             Text="Введите название или описание"
             GotFocus="SearchTextBox_GotFocus"
             LostFocus="SearchTextBox_LostFocus"
             TextChanged="SearchTextBox_TextChanged"/>

            <TextBlock Text="от" VerticalAlignment="Center" Margin="10,0,5,0"/>
            <DatePicker x:Name="DateFromPicker"
               Margin="0,0,10,0"
               VerticalAlignment="Center"/>

            <TextBlock Text="до" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker x:Name="DateToPicker"
               VerticalAlignment="Center"/>

            <Button Content="Найти"
            Click="SearchEvents_Click"
            MinWidth="80" Padding="10,5" Margin="10,0,10,0"/>
            <Button Content="Сбросить"
            Click="ResetSearch_Click"
            MinWidth="80" Padding="10,5"/>
        </StackPanel>

        <!-- Список событий -->
        <ListView x:Name="EventsList" Grid.Row="2" Margin="0,10,0,10"
                 SelectionMode="Single">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="ID"
                DisplayMemberBinding="{Binding Id}" Width="50"/>
                    <GridViewColumn Header="Дата и время"
                    DisplayMemberBinding="{Binding EventDate, StringFormat=dd.MM.yyyy HH:mm}"
                    Width="120"/>
                    <GridViewColumn Header="Название"
                DisplayMemberBinding="{Binding Title}"
                Width="250"/>
                    <GridViewColumn Header="Ежегодное" Width="80">
                        <GridViewColumn.DisplayMemberBinding>
                            <Binding Path="Annual">
                                <Binding.Converter>
                                    <local:BooleanToYesNoConverter />
                                </Binding.Converter>
                            </Binding>
                        </GridViewColumn.DisplayMemberBinding>
                    </GridViewColumn>
                    <GridViewColumn Header="Описание"
                DisplayMemberBinding="{Binding Description}"
                Width="300"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Диалоговое окно для добавления/редактирования -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1"
               Background="LightBlue" Padding="15" Visibility="Collapsed"
               x:Name="EventDialog" Opacity="0">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <Trigger Property="Visibility" Value="Visible">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                          From="0" To="1" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <!-- Заголовок диалогового окна -->
                <TextBlock x:Name="DialogTitle" Text="Добавление события"
                           FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>

                <!-- Поле для названия события -->
                <TextBox x:Name="TitleTextBox"
                         Height="25"
                         Margin="0,0,0,10"
                         Padding="5"
                         Background="White"
                         Foreground="Gray"
                         Text="Название события"
                         TextChanged="TitleTextBox_TextChanged"
                         GotFocus="TitleTextBox_GotFocus"
                         LostFocus="TitleTextBox_LostFocus"/>

                <!-- Выбор даты -->
                <DatePicker x:Name="DatePicker" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" Margin="0,10,0,10">
                    <TextBlock Text="Время:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="HourComboBox" Width="60" VerticalAlignment="Center"/>
                    <TextBlock Text=":" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox x:Name="MinuteComboBox" Width="60" VerticalAlignment="Center"/>
                </StackPanel>

                <CheckBox x:Name="IsHolidayCheckBox" Content="Ежегодное событие" Margin="0,10,0,10"/>

                <!-- Поле для описания события -->
                <TextBox x:Name="DescriptionTextBox"
                        Height="80"
                        Margin="0,0,0,10"
                        Padding="5"
                        Background="White"
                        Foreground="Gray"
                        Text="Введите описание события..."
                        TextChanged="DescriptionTextBox_TextChanged"
                        GotFocus="DescriptionTextBox_GotFocus"
                        LostFocus="DescriptionTextBox_LostFocus"/>

                <!-- Панель кнопок диалога -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                    <Button Content="Сохранить" x:Name="SaveEventButton" Click="SaveEvent_Click" MinWidth="80" Padding="10,5" Margin="0,0,10,0"/>
                    <Button Content="Отмена" Click="CancelDialog_Click" MinWidth="80" Padding="10,5"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>